# ============================================================
# BOQNOW — Environment Variables
# Copy to .env.local and fill in your values
# NEVER commit .env.local to git
# ============================================================

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://boqnow.com

# ── Anthropic (SERVER ONLY — no NEXT_PUBLIC prefix) ─────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Clerk (Auth) ─────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_...
CLERK_SECRET_KEY=sk_...
CLERK_WEBHOOK_SECRET=whsec_...
ADMIN_CLERK_USER_ID=user_...   # Your own Clerk user ID — gives admin access

# ── Supabase (Database + Storage) ────────────────────────────
DATABASE_URL=postgresql://postgres:[PASS]@db.[PROJECT].supabase.co:5432/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:[PASS]@db.[PROJECT].supabase.co:5432/postgres
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # SERVER ONLY

# ── Stripe (Payments) ────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_...
STRIPE_SECRET_KEY=sk_...           # SERVER ONLY
STRIPE_WEBHOOK_SECRET=whsec_...    # SERVER ONLY
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_AGENCY=price_...

# ── Resend (Email) ────────────────────────────────────────────
RESEND_API_KEY=re_...              # SERVER ONLY

# ── Upstash Redis (Rate Limiting) ────────────────────────────
UPSTASH_REDIS_URL=https://...upstash.io
UPSTASH_REDIS_TOKEN=...            # SERVER ONLY

# ── CloudConvert (DWG → PDF, Optional) ───────────────────────
CLOUDCONVERT_API_KEY=...

# ── VirusTotal (File scanning, Optional but recommended) ──────
VIRUSTOTAL_API_KEY=...             # Free: 500 lookups/day

# ── Sentry (Error tracking, Optional) ────────────────────────
SENTRY_DSN=https://...@sentry.io/...

# ── Provisioning scripts (scripts/provision-browser.mjs) ─────
# Local only — used to log into service dashboards during setup.
# NEVER commit real values; keep in .env.local only.
PROVISION_EMAIL=
PROVISION_PASSWORD=
PROVISION_RESEND_PASSWORD=
PROVISION_DB_PASSWORD=

# ── Local Docker (docker-compose.yml) ────────────────────────
LOCAL_POSTGRES_PASSWORD=boqnow
